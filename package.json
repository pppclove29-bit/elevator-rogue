{
  "name": "elevator-rogue",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently -k -n vite,electron -c blue,magenta \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "pnpm build && electron-builder",
    "electron:build:mac": "pnpm build && electron-builder --mac",
    "electron:build:win": "pnpm build && electron-builder --win",
    "electron:build:linux": "pnpm build && electron-builder --linux"
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.elevatorrogue.game",
    "productName": "Elevator Rogue",
    "directories": {
      "output": "release",
      "buildResources": "electron/build"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "electron/preload.cjs",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.games"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Game"
    }
  }
}
